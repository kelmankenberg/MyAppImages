{
  "name": "myappimages",
  "version": "0.1.0",
  "description": "A dockable launcher for AppImage files",
  "author": "Kelman Kenenberg",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev:main": "node node_modules/typescript/bin/tsc -p tsconfig.main.json --watch",
    "dev:preload": "node node_modules/typescript/bin/tsc -p tsconfig.preload.json --watch",
    "dev:renderer": "node node_modules/vite/bin/vite.js",
    "dev:electron": "node node_modules/electron/cli.js dist-electron/main/index.js",
    "dev": "npm run dev:main & npm run dev:preload & sleep 2 && npm run dev:renderer & sleep 1 && VITE_DEV_SERVER_URL=http://localhost:5173 npm run dev:electron",
    "build:main": "node node_modules/typescript/bin/tsc -p tsconfig.main.json",
    "build:preload": "node node_modules/typescript/bin/tsc -p tsconfig.preload.json",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer && electron-builder",
    "preview": "vite preview",
    "typecheck": "node node_modules/typescript/bin/tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "fs-extra": "^11.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1",
    "eslint": "^8.56.0",
    "prettier": "^3.2.5",
    "typescript": "^5.3.3",
    "vite": "^5.1.0",
    "vite-plugin-electron": "^0.28.0"
  }
}
